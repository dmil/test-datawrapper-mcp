# Environment variables for Datawrapper MCP Web
# Copy this file to .env and fill in your values.

# (Optional) Pre-configure an OpenRouter API key for all users.
# If set, users won't need to enter their own key in the settings panel.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# (Optional) Override the Datawrapper MCP server URL.
# Defaults to https://datawrapper-mcp.fly.dev/mcp
# MCP_URL=https://datawrapper-mcp.fly.dev/mcp

# (Optional) Default model for OpenRouter.
# Defaults to anthropic/claude-3.5-sonnet
# MODEL=anthropic/claude-3.5-sonnet

# (Optional) Port the web server listens on. Defaults to 3000.
# PORT=3000
