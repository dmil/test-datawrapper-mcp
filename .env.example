# Environment variables for Datawrapper MCP Web
# Copy this file to .env and fill in your values.

# (Required) OpenRouter API key for LLM access.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# (Required) Datawrapper API token.
# Get a token at https://app.datawrapper.de/account/api-tokens
DATAWRAPPER_TOKEN=

# (Optional) Default model for OpenRouter.
# Defaults to anthropic/claude-3-haiku
# MODEL=anthropic/claude-3-haiku

# (Optional) Port the web server listens on. Defaults to 3000.
# PORT=3000
